{
  "name": "url-minify",
  "version": "2.8.8",
  "description": "Library to shorten url without any api keys",
  "keywords": [],
  "homepage": "https://github.com/rubiin/url-minify#readme",
  "bugs": "https://github.com/rubiin/url-minify/issues",
  "license": "MIT",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/url-minify.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "npm run build",
    "release": "bumpp && pnpm publish",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@rubiin/tsconfig": "^2.2.0",
    "@types/node": "^24.12.4",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
